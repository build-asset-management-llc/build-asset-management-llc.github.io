---
const {id, open} = Astro.props;
---

<style>
    .modal {
        display: none;
        position: fixed;
        z-index: 1;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.4);
    }
    .modal-content {
        margin: 15% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 35%;
    }
    .close {
        font-size: 30px;
        float: left;
        cursor: pointer;
    }
    .close:hover,
    .close:focus {
        cursor: pointer;
    }
</style>

<div id="myModal" class="modal">
    <div class="modal-content bg-inkblue text-white">
        <span class="close text-white text-lg hover:text-jade focus:text-jade">&times;</span>
        <div id="result" class="text-white"></div>
    </div>
</div>